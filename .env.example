# =============================================================================
# nanobot-docker — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# All nanobot settings use the NANOBOT_ prefix with __ as nested key separator.
# See: https://nanobot.wiki/docs/0.1.5.post2/use-nanobot/configuration
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Provider & Model
# -----------------------------------------------------------------------------
# Choose provider: openrouter, openai, anthropic, google, deepseek, etc.
NANOBOT_PROVIDER=openrouter

# Model identifier in provider/model format.
# Examples:
#   openrouter  → anthropic/claude-sonnet-4-7, openai/gpt-4o-mini, deepseek/deepseek-chat-v3
#   openai     → gpt-4o-mini, gpt-4o
#   anthropic  → claude-sonnet-4-7, claude-opus-4-5
NANOBOT_MODEL=anthropic/claude-sonnet-4-7

# Your IANA timezone (used for cron scheduling and timestamps)
NANOBOT_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# REQUIRED: Provider API Keys
# Add at least one key for the provider you chose above.
# -----------------------------------------------------------------------------
# OpenRouter key (recommended — access 100+ models via single API)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# OpenAI key (direct — gpt-4o, gpt-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic key (direct — claude-4, claude-3.5, etc.)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google key (direct — gemini-2.5, etc.)
GOOGLE_API_KEY=your-google-api-key

# DeepSeek key (direct — deepseek-chat-v3, etc.)
DEEPSEEK_API_KEY=your-deepseek-api-key

# -----------------------------------------------------------------------------
# OPTIONAL: Gateway & API Server Ports
# -----------------------------------------------------------------------------
# Gateway port (receives webhook events from Telegram/Discord/etc.)
# Default: 18790
# GATEWAY_PORT=18790

# OpenAI-compatible API server port
# Default: 8900
# API_PORT=8900

# -----------------------------------------------------------------------------
# OPTIONAL: Channel Configuration
# Only fill in the channels you intend to use.
# After running `docker compose run --rm nanobot-cli onboard`, you can also
# edit ~/.nanobot/config.json directly or use the --wizard flag.
# -----------------------------------------------------------------------------
# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Discord
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# Email
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=you@example.com
# EMAIL_SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=you@example.com

# -----------------------------------------------------------------------------
# OPTIONAL: Tools & Security
# -----------------------------------------------------------------------------
# Exec sandbox: "" (none) or "bwrap" (Linux only, recommended on Linux hosts)
# NANOBOT_TOOLS__EXEC__SANDBOX=bwrap

# Restrict file/exec operations to workspace directory
# NANOBOT_TOOLS__RESTRICT_TO_WORKSPACE=false

# SSRF whitelist CIDR ranges (e.g. for Tailscale access)
# NANOBOT_TOOLS__SSRF_WHITELIST=100.64.0.0/10

# -----------------------------------------------------------------------------
# OPTIONAL: Agent Behavior
# -----------------------------------------------------------------------------
# Max tool-call rounds per user message (default: 200)
# NANOBOT_AGENTS__DEFAULTS__MAX_TOOL_ITERATIONS=200

# Auto-compact session after N minutes of inactivity (default: null = disabled)
# NANOBOT_AGENTS__DEFAULTS__IDLE_COMPACT_AFTER_MINUTES=60

# Merge all channel sessions into one unified conversation
# NANOBOT_AGENTS__DEFAULTS__UNIFIED_SESSION=false

# LLM reasoning effort: low, medium, high, adaptive, or null
# NANOBOT_AGENTS__DEFAULTS__REASONING_EFFORT=null
