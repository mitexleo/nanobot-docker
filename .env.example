# Environment Variables for nanobot-docker
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: LLM Provider Configuration
# ============================================

# Choose your provider: openai, anthropic, google, deepseek, etc.
MODEL_PROVIDER=openai

# Model settings
GPT_MODEL=gpt-4o-mini

# ============================================
# REQUIRED: API Keys
# ============================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google API Key (for Gemini)
GOOGLE_API_KEY=your-google-api-key

# DeepSeek API Key
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================
# OPTIONAL: API Server Configuration
# ============================================

API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000
# Comma-separated list of API keys for authentication
API_KEYS=your-secure-api-key

# ============================================
# OPTIONAL: Channel Configurations
# ============================================

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ============================================
# OPTIONAL: Session Settings
# ============================================

SESSION_NAME=nanobot_session
AUTO_COMPACT=true
